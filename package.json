{
  "name": "legendary-arena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Legendary Arena monorepo — card registry, viewer, and tooling",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "registry:validate":    "pnpm --filter @legendary-arena/registry validate",
    "registry:build":       "pnpm --filter @legendary-arena/registry build",
    "registry:upload":      "pnpm --filter @legendary-arena/registry upload",
    "viewer:dev":           "pnpm --filter registry-viewer dev",
    "viewer:build":         "pnpm registry:build && pnpm --filter registry-viewer build",

    "migrate":              "node --env-file=.env scripts/migrate.mjs",

    "check":                "node --env-file=.env scripts/check-connections.mjs",
    "check:ec":             "node --env-file=.env scripts/ec/health-check.ec.mjs",
    "check:env":            "pwsh scripts/Check-Env.ps1",

    "validate":             "node scripts/validate-r2.mjs",
    "validate:ps":          "pwsh scripts/Validate-R2.ps1",
    "validate:r2":          "pwsh scripts/Validate-R2.ps1 -R2Mode",
    "validate:r2:fast":     "pwsh scripts/Validate-R2.ps1 -R2Mode -SkipImages",

    "arch:inventory":       "node scripts/architecture-inventory.mjs",
    "arch:inventory:save":  "node scripts/architecture-inventory.mjs --out docs/ai/audits/architecture-inventory-latest.md"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
