{
  "name": "legendary-arena",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Legendary Arena monorepo — card registry, viewer, and tooling",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "registry:validate":    "pnpm --filter @legendary-arena/registry validate",
    "registry:build":       "pnpm --filter @legendary-arena/registry build",
    "registry:upload":      "pnpm --filter @legendary-arena/registry upload",
    "viewer:dev":           "pnpm --filter registry-viewer dev",
    "viewer:build":         "pnpm registry:build && pnpm --filter registry-viewer build",

    "wiki-viewer:project":     "node apps/wiki-viewer/scripts/project-wiki.mjs",
    "wiki-viewer:check-links": "node apps/wiki-viewer/scripts/check-links.mjs",
    "wiki-viewer:inventory":   "node scripts/architecture-inventory.mjs --out wiki/architecture-inventory.md",
    "wiki-viewer:build":       "pnpm run wiki-viewer:project && pnpm run wiki-viewer:check-links && hugo --source apps/wiki-viewer --minify",
    "wiki-viewer:dev":         "pnpm run wiki-viewer:project && hugo server --source apps/wiki-viewer --port 1313",

    "migrate":              "node --env-file=.env scripts/migrate.mjs",
    "sweep:nightly":        "node scripts/sweep-submit.mjs",
    "sweep:generate-axis":  "node scripts/sweep-generate-full-axis.mjs",
    "sweep:weekly-plan":    "node scripts/sweep-weekly-plan.mjs",
    "sweep:weekly-submit":  "node scripts/sweep-weekly-submit.mjs",
    "inspection:fetch":     "node scripts/inspection-fetch.mjs",
    "inspection:triage":    "node scripts/inspection-triage.mjs",
    "inspection:submit":    "node scripts/inspection-submit.mjs",
    "handoffs:sync":        "node scripts/handoffs-sync.mjs",
    "handoffs:verify":      "node scripts/handoffs-verify.mjs",

    "check":                "node --env-file=.env scripts/check-connections.mjs",
    "check:ec":             "node --env-file=.env scripts/ec/health-check.ec.mjs",
    "check:env":            "pwsh scripts/Check-Env.ps1",
    "check:domains":        "node scripts/check-subdomains.mjs",
    "check:incident":       "node --env-file=.env scripts/check-connections.mjs && node scripts/check-subdomains.mjs --live-only",

    "validate":             "node scripts/validate-r2.mjs",
    "validate:ps":          "pwsh scripts/Validate-R2.ps1",
    "validate:r2":          "pwsh scripts/Validate-R2.ps1 -R2Mode",
    "validate:r2:fast":     "pwsh scripts/Validate-R2.ps1 -R2Mode -SkipImages",

    "dash:dev":             "pnpm --filter @legendary-arena/dashboard dev",
    "dash:build":           "pnpm --filter @legendary-arena/dashboard build",

    "arch:inventory":       "node scripts/architecture-inventory.mjs",
    "arch:inventory:save":  "node scripts/architecture-inventory.mjs --out docs/ai/audits/architecture-inventory-latest.md",

    "roadmap:counts":       "node scripts/roadmap-counts.mjs",
    "roadmap:counts:write": "node scripts/roadmap-counts.mjs --write",
    "roadmap:counts:check": "node scripts/roadmap-counts.mjs --check",
    "roadmap:counts:test":  "node --import tsx --test scripts/roadmap-counts.test.ts",

    "themes:check-slugs":   "node scripts/check-theme-slug-resolution.mjs",
    "themes:check-slugs:check": "node scripts/check-theme-slug-resolution.mjs --check"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@legendary-arena/game-engine": "workspace:*",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "generator-function": "1.0.0"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
