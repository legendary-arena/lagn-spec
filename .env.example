# ── Database ──────────────────────────────────────────────────────────────────
# Render auto-wires this from the managed PostgreSQL service.
# For local dev, use a local PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/legendary_arena

# Used by check-connections.mjs to verify the correct DB is connected.
EXPECTED_DB_NAME=legendary_arena

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a secure value with:
# node --input-type=module -e "import { randomBytes } from 'node:crypto'; console.log(randomBytes(32).toString('hex'))"
# Never commit a real value. Rotate by updating the Render env var and redeploying.
JWT_SECRET=your-32-byte-hex-string-here

# ── Game Server ───────────────────────────────────────────────────────────────
# Set to 'production' in the Render dashboard; use 'development' in .env locally.
NODE_ENV=development

# Public URL of the Render Web Service (no trailing slash).
GAME_SERVER_URL=https://legendary-arena.onrender.com

# Local dev port. Render sets PORT automatically — do not add to Render env vars.
PORT=8000

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Public base URL of the R2 bucket (no trailing slash).
R2_PUBLIC_URL=https://images.legendary-arena.com

# Public URL of the registry-viewer Cloudflare Pages deployment.
# (Distinct from ARENA_CLIENT_URL below — different CF Pages project.)
CF_PAGES_URL=https://cards.barefootbetters.com

# Public URL of the gameplay-client (arena-client) Cloudflare Pages
# deployment. Used by check-connections.mjs to probe CORS allowlists
# (broker tenant + API server), to confirm the deployed SPA proxies
# /api/* to the API server (not its SPA fallback), and to verify Vite
# inlined VITE_* env vars into the production bundle. Optional —
# defaults to https://legendary-arena-play.pages.dev (the production
# Pages project hostname declared in EC-147 and the server's
# Server({ origins }) allowlist). Override for staging or branch-
# preview testing.
ARENA_CLIENT_URL=https://legendary-arena-play.pages.dev

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# VITE_ prefix is required to expose this variable to the browser bundle.
# Local dev: http://localhost:8000 | Production: same as GAME_SERVER_URL
VITE_GAME_SERVER_URL=https://legendary-arena.onrender.com

# ── Hanko Session Verifier (WP-126) ───────────────────────────────────────────
# Tenant-scoped origin per Hanko Cloud's /{tenant_id}/.well-known/jwks.json
# endpoint shape. Replace YOUR_TENANT_ID with the tenant ID from the Hanko
# dashboard. The verifier appends /.well-known/jwks.json programmatically.
HANKO_TENANT_BASE_URL=https://passkeys.hanko.io/YOUR_TENANT_ID

# Audience identifier configured in the Hanko tenant; matched against the
# JWT `aud` claim by the verifier.
HANKO_EXPECTED_AUDIENCE=legendary-arena

# Optional: JWKS refresh interval in milliseconds. Absence yields the
# D-12603 default of 300_000 ms (5 minutes).
HANKO_JWKS_REFRESH_INTERVAL_MS=300000

# ── Admin Gate (WP-110) ───────────────────────────────────────────────────────
# Shared secret for /api/admin/* routes. Generate a secure value with:
# node --input-type=module -e "import { randomBytes } from 'node:crypto'; console.log(randomBytes(32).toString('hex'))"
# Fail-closed: if not set, all admin routes return 401.
ADMIN_SECRET=your-admin-secret-here

# ── Stripe Billing (WP-133) ───────────────────────────────────────────────────
# Stripe secret key (sk_test_* in test mode; sk_live_* in production). Provision
# in the Render dashboard; never commit a real value.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe webhook signing secret (whsec_*). Found in the Stripe dashboard under
# Developers -> Webhooks -> Signing secret for each registered endpoint.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Comma-separated price-id-to-entitlement-key allowlist parsed at startup.
# Format: priceId1:entitlementKey1,priceId2:entitlementKey2
# Every entitlementKey value MUST be a member of ENTITLEMENT_KEYS in
# apps/server/src/entitlements/entitlements.types.ts; startup throws on a
# non-member value.
STRIPE_PRICE_ALLOWLIST=price_supporter_2026:supporter_tier_basic_2026,price_playmat_classic:cosmetic_playmat_classic

# Public base URL of the deployed application (no trailing slash). Used to
# server-derive the Stripe Checkout success_url and cancel_url per D-13309 —
# accepting either URL from request input would permit a redirect-manipulation
# attack.
PUBLIC_BASE_URL=https://app.legendary-arena.com
