# why: the LIVE fetchers append `/api/...` to this base, so it must be the API
# ORIGIN with no path suffix. Production value is https://api.legendary-arena.com.
VITE_API_BASE_URL=http://localhost:3001
# why: Hanko tenant origin (same value the game client + server use as
# HANKO_TENANT_BASE_URL). Passed to <hanko-auth :api> and initializeHankoClient.
# Empty/unset → the dashboard falls back to the LoginPage's 'unavailable' state.
VITE_HANKO_TENANT_BASE_URL=
VITE_WS_URL=ws://localhost:3001/ws/dash
VITE_USE_MOCKS=true
VITE_FEATURE_FLAGS=alerts
