{
  "name": "@legendary-arena/dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Internal admin dashboard SPA for Legendary Arena (Vue 3 + PrimeVue 4 + Vite)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-governance-snapshot.mjs && vite build",
    "prebuild:snapshot": "node scripts/build-governance-snapshot.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "echarts": "^5.5.0",
    "pinia": "^2.1.7",
    "primevue": "^4.0.0",
    "@primevue/themes": "^4.0.0",
    "vue": "^3.4.27",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.0.5",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.19"
  }
}
