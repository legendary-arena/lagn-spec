# VITE_SERVER_URL — base URL of the boardgame.io game server.
#
# Per-environment source:
#   - Local development: copy this file to `.env` (gitignored) and set the URL.
#     Default fallback in code is http://localhost:8000.
#   - Cloudflare Pages: inject as a build-time environment variable in the
#     Pages project settings; Vite statically inlines it into the client bundle.
#   - Production: TBD (set in the deployment environment before the build runs).
VITE_SERVER_URL=http://localhost:8000

# VITE_API_BASE_URL — base URL of the HTTP API server (Express, hosting
# /api/me/*, /api/admin/*, /api/players/*). Distinct from VITE_SERVER_URL
# (which targets the boardgame.io WS transport); in current production
# both happen to point at the same host (api.legendary-arena.com), but
# they remain independently configurable for future deployment topologies.
#
# Per-environment source:
#   - Local development: copy this file to `.env` (gitignored) and set the URL.
#     Default fallback in code is http://localhost:8000.
#   - Cloudflare Pages: inject as a build-time environment variable in the
#     Pages project settings; Vite statically inlines it into the client bundle.
#   - Production: set in the Cloudflare Pages project settings before the
#     build runs (the fallback http://localhost:8000 fails visibly if
#     missing — by design, loud failure beats silent SPA-fallback HTML).
#
# why: arena-client API clients prefix every fetch via buildApiUrl(...)
# from src/lib/api/apiBaseUrl.ts (per WP-161 / D-16101). Without this
# variable set on production, Vite inlines the localhost fallback and
# every API call fails — which is the intended diagnostic surface for
# operator misconfiguration.
VITE_API_BASE_URL=http://localhost:8000

# VITE_HANKO_TENANT_BASE_URL — authentication broker tenant origin
# (matches server HANKO_TENANT_BASE_URL).
#
# Per-environment source:
#   - Local development: set in `.env` to your dev tenant URL.
#   - Cloudflare Pages: inject as a build-time environment variable in the
#     Pages project settings; Vite statically inlines it into the client bundle.
#   - Production: set in the Cloudflare Pages project settings before the
#     build runs.
#
# why: the server's HANKO_TENANT_BASE_URL (set in render.yaml / the Render
# dashboard per WP-126 / D-12602) and the client's VITE_HANKO_TENANT_BASE_URL
# MUST point at the same tenant — the server validates tokens against the
# tenant's JWKS, and the client obtains tokens from the same tenant.
VITE_HANKO_TENANT_BASE_URL=https://your-tenant-id.hanko.io
