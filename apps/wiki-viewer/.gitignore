# Build outputs — regenerated by `pnpm wiki-viewer:build`. The projection
# target and rendered site are derived from docs/wiki/ and apps/wiki-viewer/
# source, never authored by hand. Tracking them would (a) bloat the repo
# and (b) create a second authoring surface that drifts from docs/wiki/.
content/
public/
resources/
# Projected ewiki asset directories (ewiki/<slug>/ → static/<slug>/)
static/*/

# Hugo's transient build-state lock — created during `hugo` / `hugo server`
# and removed on clean exit, but lingers if a build is interrupted. Never
# meant to be tracked.
.hugo_build.lock
