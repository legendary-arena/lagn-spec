node_modules/
dist/
.env
*.env.local
.DS_Store
*.log

# Generated build artifacts — regenerated by CI
packages/registry/dist/
apps/registry-viewer/dist/

# Claude Code local settings (per-machine, not shared)
.claude/settings.local.json

# Claude Code transient worktrees (auto-generated session sandboxes; never commit)
.claude/worktrees/

# Claude Code transient harness state (ScheduleWakeup lock; written/deleted continuously during sessions)
.claude/scheduled_tasks.lock

# Invocation scratchpads — preflight / copilot / session-prompt files behave
# like REPL transcripts. session-context-* files in docs/ai/session-context/
# remain committed as governance artifacts. Override: `git add -f <path>` if
# a WP or EC cites a specific file normatively. See .claude/rules/work-packets.md
# §Invocation Artifacts (Commit Policy).
docs/ai/invocations/preflight-*.md
docs/ai/invocations/copilot-*.md
docs/ai/invocations/session-*.md

# Images after standardization (large binary files)
# Commit images/raw/ as source of truth; images/standard/ is generated
images/standard/

# Theme media assets (audio/images — hosted on R2, not in git)
content/media/

# Generated theme bundle (regenerated by 00-ScriptCombindJSON.ps1)
content/themes/00-ALL_THEMES_COMBINED.json
content/themes/01-ALL_THEMES_COMBINED.json

# Architecture inventory — regenerated by `pnpm arch:inventory:save`.
# Run ad hoc; never committed (would churn on every run). Dated
# snapshots can still be committed manually with `git add -f` when a
# WP / review wants a frozen reference.
docs/ai/audits/architecture-inventory-latest.md
